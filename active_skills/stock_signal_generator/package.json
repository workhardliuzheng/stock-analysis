{
  "name": "股票分析系统数据与信号",
  "description": "自动化股市数据同步与信号生成（内部使用）",
  "version": "1.0.1",
  "author": "Zeno",
  "skill_id": "stock_analysis_signal_generator",
  "private": true,
  "commands": {
    "full": {
      "description": "完整执行: 同步数据 + 计算信号 + 生成报告",
      "script": "run_signal_generator.py"
    },
    "sync": {
      "description": "仅同步指数数据",
      "script": "sync_data.py"
    },
    "signals": {
      "description": "仅计算信号",
      "script": "calculate_signals.py"
    },
    "advisor": {
      "description": "生成投资顾问报告（明确买卖结论）",
      "script": "investment_advisor.py"
    },
    "report": {
      "description": "生成信号分析报告",
      "script": "report_generator.py"
    }
  },
  "requirements": [
    "tushare",
    "pandas",
    "numpy",
    "xgboost",
    "scikit-learn",
    "optuna"
  ],
  "config": {
    "default_indices": [
      "000688.SH",
      "399006.SZ",
      "000001.SH",
      "000905.SH",
      "000852.SH"
    ],
    "default_start_date": "20230101",
    "tushare_token_required": false
  }
}
